{
	"schemaVersion": "0.1.0",
	"name": "Debug - FullHTML Raw",
	"behavior": "create",
	"noteNameFormat": "{{title}}",
	"path": "Clippings/LLM",
	"noteContentFormat": "{{fullHtml|replace:\"/<div[^>]*class=\\\"very-large-text-container\\\"[^>]*>([\\s\\S]*?)<\\/div>/\":\"$1\"}}",
	"properties": [
		{ "name": "title", "value": "{{title}}", "type": "text" },
		{ "name": "source", "value": "{{url}}", "type": "text" },
		{ "name": "created", "value": "{{date}}", "type": "text" },
		{ "name": "tags", "value": "debug", "type": "text" }
	],
	"triggers": ["https://aistudio.google.com"]
}
