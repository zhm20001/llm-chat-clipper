{
	"schemaVersion": "0.1.0",
	"name": "LLM Chat - Google AI Studio",
	"behavior": "create",
	"noteNameFormat": "{{title}}",
	"path": "Clippings/LLM",
	"noteContentFormat": "{{contentHtml|replace:\"/<p>\\s*Thoughts\\s*<\\/p>[\\s\\S]*?(?=<h[23]>)/g\":\"\"|replace:\"/<p>\\s*[\\d,]+\\s*tokens\\s*<\\/p>/g\":\"\"|replace:\"/<p>\\s*Model\\s*<\\/p>/g\":\"\"|replace:\"/<p>\\s*Text\\s*<\\/p>/g\":\"\"|markdown|replace:\"/^(Mermaid|JavaScript|Python|TypeScript|HTML|CSS|Bash|Shell|SQL|JSON|YAML|XML|Java|Go|Rust|Ruby|PHP|Swift|Kotlin)\\s*\\\\n\\\\n(```)/gm\":\"```$1\"}}",
	"properties": [
		{ "name": "title", "value": "{{title}}", "type": "text" },
		{ "name": "source", "value": "{{url}}", "type": "text" },
		{ "name": "created", "value": "{{date}}", "type": "text" },
		{ "name": "tags", "value": "llm-chat,aistudio", "type": "text" }
	],
	"triggers": ["https://aistudio.google.com"]
}
