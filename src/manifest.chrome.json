{
	"manifest_version": 3,
	"default_locale": "en",
	"name": "LLM Chat Clipper",
	"homepage_url": "https://github.com/user/obsidian-clipper",
	"version": "0.1.0",
	"description": "Extract LLM chat conversations as structured Markdown. Based on Obsidian Web Clipper.",
	"permissions": [
		"activeTab",
		"clipboardWrite",
		"commands",
		"contextMenus",
		"storage",
		"scripting"
	],
	"host_permissions": [
		"<all_urls>",
		"http://*/*",
		"https://*/*"
	],
	"action": {
		"default_popup": "popup.html"
	},
	"options_ui": {
		"page": "settings.html",
		"open_in_tab": true
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"background": {
		"service_worker": "background.js"
	},
	"content_scripts": [
		{
			"matches": ["http://*/*", "https://*/*"],
			"js": ["browser-polyfill.min.js", "content.js"]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["browser-polyfill.min.js", "style.css", "flatten-shadow-dom.js"],
			"extension_ids": ["*"],
			"matches": [ "*://*/*" ]
		}
	],
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"commands": {
		"_execute_action": {
			"suggested_key": {
				"default": "Ctrl+Shift+O",
				"mac": "Command+Shift+O"
			},
			"description": "__MSG_commandOpenClipper__"
		},
		"quick_clip": {
			"suggested_key": {
				"default": "Alt+Shift+O",
				"mac": "Alt+Shift+O"
			},
			"description": "__MSG_commandQuickClip__"
		}
	}
}
